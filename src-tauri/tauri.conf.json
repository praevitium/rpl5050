{
  "productName": "rpl.ai",
  "version": "0.2.0",
  "identifier": "com.rpl5050.rplai",
  "build": {
    "beforeBuildCommand": "node scripts/build-frontend-dist.mjs",
    "beforeDevCommand": { "script": "node scripts/build-frontend-dist.mjs", "wait": true },
    "frontendDist": "../www-dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "rpl.ai - AI-Assisted RPL Calculator",
        "width": 600,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.13"
    }
  }
}
